@model List<CRUD.Models.SinhVien>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<h2>Kết quả tìm kiếm</h2>

<a asp-action="Search" class="btn btn-secondary mb-3">
    Quay lại danh sách
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Họ tên</th>
            <th>Tuổi</th>
            <th>Lớp</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var sv in Model)
            {
                <tr>
                    <td>@sv.Id</td>
                    <td>@sv.HoTen</td>
                    <td>@sv.Tuoi</td>
                    <td>@sv.Lop</td>
                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@sv.Id"
                           class="btn btn-warning btn-sm">
                            Sửa
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@sv.Id"
                           class="btn btn-danger btn-sm">
                            Xóa
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">
                    Không tìm thấy sinh viên nào.
                </td>
            </tr>
        }
    </tbody>
</table>
