@model List<CRUD.Models.SinhVien>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2>Danh sách sinh viên</h2>
<a asp-action="Create" class="btn btn-primary mb-3">
    ADD
</a>
<a asp-action="ExportExcel" class="btn btn-success">
    Export Excel
</a>
<form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
    <input type="file" name="file" accept=".xlsx" class="form-control" />
    <button type="submit" class="btn btn-success mt-2">
        Import Excel
    </button>
</form>
<form asp-action="Search" method="get">
    <input type="text"
           name="searchString"
           value="@ViewData["CurrentFilter"]"
           placeholder="Nhập tên sinh viên..." />

    <button type="submit">Tìm kiếm</button>
</form>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Họ tên</th>
            <th>Tuổi</th>
            <th>Lớp</th>
            <th>Ảnh</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sv in Model)
        {
            <tr>
                <td>@sv.Id</td>
                <td>@sv.HoTen</td>
                <td>@sv.Tuoi</td>
                <td>@sv.Lop</td>
                <td><img src="~/images/@sv.Anh" width="100" height="100" style="object-fit:cover" /></td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@sv.Id"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@sv.Id"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>


</table>

<div class="mt-3">
    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="Index"
           asp-route-page="@i"
           class="btn @(i == ViewBag.CurrentPage ? "btn-primary" : "btn-outline-primary")">
            @i
        </a>
    }
</div>
